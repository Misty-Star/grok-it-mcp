{
  "name": "grok-it-mcp",
  "version": "0.3",
  "description": "Agent plugin wrapper around a local MCP server for Grok x_search, image generation, and video generation.",
  "type": "module",
  "bin": {
    "grok-it-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/make-bin-executable.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "validate": "npm run typecheck && npm test && npm run build && npm run validate:plugin && npm run validate:codex-plugin",
    "validate:codex-plugin": "node scripts/validate-codex-plugin.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "toml": "3.0.0",
    "typescript": "5.9.3",
    "vitest": "4.0.15",
    "yaml": "2.8.2"
  }
}
